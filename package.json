{
  "name": "spot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "codegen": "apollo client:codegen --target typescript --localSchemaFile schema.gql --outputFlat --includes \"{pages,src}/**\" --excludes \"src/generated/**\" src/generated",
    "codegen:watch": "yarn codegen --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "lint": "next lint",
    "format": "prettier --write \".\"",
    "format:check": "prettier --check \".\"",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@apollo/client": "^3.2.5",
    "@prisma/client": "^5.22.0",
    "@reach/combobox": "^0.11.2",
    "apollo-server-micro": "^2.19.0",
    "autoprefixer": "^10.0.2",
    "class-validator": "^0.12.2",
    "cloudinary": "^1.23.0",
    "cloudinary-react": "^1.6.7",
    "cookie": "^0.4.1",
    "deepmerge": "^4.2.2",
    "firebase": "^8.0.2",
    "firebase-admin": "^9.4.1",
    "geolib": "^3.3.1",
    "graphql": "^15.4.0",
    "js-cookie": "^2.2.1",
    "next": "^14.2.0",
    "postcss": "^8.4.31",
    "postcss-import": "^14.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-firebaseui": "^4.1.0",
    "react-hook-form": "^6.11.1",
    "react-icons": "^4.3.1",
    "react-map-gl": "^5.2.10",
    "reflect-metadata": "^0.1.13",
    "sharp": "^0.33.0",
    "tailwindcss": "^2.0.1",
    "type-graphql": "^1.1.1",
    "use-debounce": "^5.0.4",
    "use-google-maps-script": "^0.1.0",
    "use-places-autocomplete": "^1.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.0",
    "@babel/plugin-proposal-class-properties": "^7.12.1",
    "@babel/plugin-proposal-decorators": "^7.12.1",
    "@types/cookie": "^0.4.1",
    "@types/js-cookie": "^2.2.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-map-gl": "^5.2.9",
    "apollo": "^2.31.1",
    "babel-plugin-parameter-decorator": "^1.0.16",
    "babel-plugin-transform-typescript-metadata": "^0.3.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss-flexbugs-fixes": "^5.0.1",
    "postcss-preset-env": "^6.7.0",
    "prettier": "^3.3.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.0"
  },
  "resolutions": {
    "graphql": "15.4",
    "@types/react": "^18.3.0"
  }
}
