{
  "name": "spot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "codegen": "ts-node --project tsconfig.scripts.json scripts/print-schema.ts && graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "lint": "next lint",
    "format": "prettier --write \".\"",
    "format:check": "prettier --check \".\"",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@apollo/client": "^3.13.0",
    "@apollo/server": "^4.13.0",
    "@as-integrations/next": "^3.2.0",
    "@auth/prisma-adapter": "^2.9.0",
    "@prisma/client": "^5.22.0",
    "@reach/combobox": "^0.11.2",
    "autoprefixer": "^10.0.2",
    "class-validator": "^0.14.3",
    "cloudinary": "^1.23.0",
    "cloudinary-react": "^1.6.7",
    "cookie": "^0.4.1",
    "deepmerge": "^4.2.2",
    "geolib": "^3.3.1",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.25.0",
    "js-cookie": "^2.2.1",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.31",
    "postcss": "^8.4.31",
    "postcss-import": "^14.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^6.11.1",
    "react-icons": "^4.3.1",
    "react-map-gl": "^5.2.10",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.0",
    "tailwindcss": "^2.0.1",
    "type-graphql": "2.0.0-rc.4",
    "use-debounce": "^5.0.4",
    "use-google-maps-script": "^0.1.0",
    "use-places-autocomplete": "^1.6.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@types/cookie": "^0.4.1",
    "@types/js-cookie": "^2.2.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-map-gl": "^5.2.9",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss-flexbugs-fixes": "^5.0.1",
    "postcss-preset-env": "^6.7.0",
    "prettier": "^3.3.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  },
  "resolutions": {
    "@types/react": "^18.3.0"
  }
}
